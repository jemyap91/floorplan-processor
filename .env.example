# Vision AI provider: "gemini" (default) or "qwen"
VISION_PROVIDER=gemini

# --- Gemini (Google) ---
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# --- Qwen VL (Alibaba DashScope) ---
# Get your key at: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key-here
QWEN_MODEL=qwen-vl-max
QWEN_FALLBACK_MODEL=qwen-vl-plus
# Use intl endpoint outside China, or dashscope.aliyuncs.com for Beijing region
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# SQLite database path (default: ./floorplan.db)
DB_PATH=./floorplan.db
